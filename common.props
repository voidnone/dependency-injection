<Project>
    <PropertyGroup>
        <TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <LangVersion>latest</LangVersion>
        <NoWarn>$(NoWarn);1591;</NoWarn>
        <Authors>huanent</Authors>
        <AssemblyName>VoidNone.$(MSBuildProjectName)</AssemblyName>
        <RootNamespace>VoidNone.$(MSBuildProjectName.Replace(" ", "_"))</RootNamespace>
        <RepositoryType>git</RepositoryType>
        <PackageProjectUrl>https://github.com/voidnone/dependency-injection</PackageProjectUrl>
        <RepositoryUrl>https://github.com/voidnone/dependency-injection.git</RepositoryUrl>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
    </PropertyGroup>
</Project>